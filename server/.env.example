# Required — admin dashboard password
ADMIN_PASSWORD=change-me

# Required for email — get from resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Required for email links/logo — your Vercel frontend URL (no trailing slash)
# FRONTEND_URL=https://your-site.vercel.app

# Hyp/Caspit payment terminal — set in Render's environment variables once
# Hyp provides the credentials. Leave empty to show "not configured" in the UI.
# HYP_TERMINAL_NUMBER=
# HYP_MID=
# HYP_SLAVE_TERMINAL=001

# Optional — comma-separated list of allowed origins (set to your Vercel URL in production)
# CORS_ORIGIN=https://your-site.vercel.app

# Optional — directory for the SQLite file (set to a persistent disk mount on Render)
# DATA_DIR=/var/data

# Optional — port (Render sets this automatically)
# PORT=3001
